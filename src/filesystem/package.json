{
  "name": "@adpharm/mcp-server-filesystem-ro",
  "version": "0.6.3",
  "description": "Read-only MCP server for filesystem access (fork of @modelcontextprotocol/server-filesystem)",
  "license": "SEE LICENSE IN LICENSE",
  "mcpName": "io.github.adpharm/mcp-server-filesystem-ro",
  "author": "The Adpharm (fork of Model Context Protocol, a Series of LF Projects, LLC.)",
  "homepage": "https://github.com/adpharm/mcp-servers-fork/tree/main/src/filesystem",
  "bugs": "https://github.com/adpharm/mcp-servers-fork/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/adpharm/mcp-servers-fork.git",
    "directory": "src/filesystem"
  },
  "type": "module",
  "bin": {
    "mcp-server-filesystem-ro": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^8.0.3",
    "glob": "^10.5.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/diff": "^5.0.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2.1.8",
    "shx": "^0.3.4",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
